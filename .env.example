# Global
NODE_ENV=development
APP_NAME=smart-attendance

# Web
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_ENABLE_PWA=true

# API
PORT=4000
API_PREFIX=api
JWT_ACCESS_SECRET=replace_me_access_secret
JWT_REFRESH_SECRET=replace_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Database
# Local-first default: use your standalone PostgreSQL service on this machine.
DATABASE_URL=postgresql://mtc_admin:mtc_secret_2026@127.0.0.1:5432/smart_attendance?schema=public

# Redis
# Optional for local boot in the current codebase. Leave as-is if you run Redis locally.
REDIS_URL=redis://127.0.0.1:6379

# Security / anti-fraud
ATTENDANCE_NONCE_TTL_SECONDS=120
ATTENDANCE_MAX_DISTANCE_METERS=150
ATTENDANCE_MIN_ACCURACY_METERS=80
ALLOW_OFFLINE_SUBMISSION=false
VPN_CHECK_PROVIDER=disabled

# Seed
SEED_BRANCH_COUNT=5
SEED_EMPLOYEE_COUNT=50
