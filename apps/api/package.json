{
  "name": "@smart-attendance/api",
  "private": true,
  "scripts": {
    "dev": "node --env-file=../../.env ./node_modules/@nestjs/cli/bin/nest.js start --watch",
    "build": "nest build",
    "start": "node --env-file=../../.env dist/src/main.js",
    "start:prod": "node --env-file=../../.env dist/src/main.js",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/reports.test.ts test/seed.test.ts test/manager-scoping.test.ts test/manual-correction.test.ts test/attendance.test.ts",
    "test:watch": "tsx --test --watch test",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:generate": "node --env-file=../../.env ./node_modules/prisma/build/index.js generate",
    "db:push": "node --env-file=../../.env ./node_modules/prisma/build/index.js db push --skip-generate",
    "db:migrate": "node --env-file=../../.env ./node_modules/prisma/build/index.js migrate dev",
    "db:seed": "node --env-file=../../.env ./node_modules/tsx/dist/cli.mjs prisma/seed.ts",
    "db:studio": "node --env-file=../../.env ./node_modules/prisma/build/index.js studio"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^8.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.0.0",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
